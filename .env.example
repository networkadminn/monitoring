# Database Configuration
DB_HOST=localhost
DB_NAME=site_monitor
DB_USER=monitor_user
DB_PASS=your_secure_password_here
DB_CHARSET=utf8mb4

# SMTP / Email Configuration
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password_here
FROM_EMAIL=noreply@example.com
FROM_NAME=Site Monitor

# Monitoring Behavior
ALERT_COOLDOWN=3600
CHECK_TIMEOUT=30
LOG_RETENTION_DAYS=90

# Dashboard Authentication
# Generate new hash: php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
DASHBOARD_AUTH=true
DASHBOARD_USER=admin
DASHBOARD_PASS=$2y$10$your_bcrypt_hash_here

# Application Settings
APP_URL=https://monitoring.example.com
APP_ENV=production

# SMS Alerts (Optional)
ENABLE_SMS_ALERTS=false
SMS_API_ENDPOINT=
SMS_API_KEY=

# Telegram Alerts (Optional)
ENABLE_TELEGRAM_ALERTS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Microsoft Teams Alerts
ENABLE_TEAMS_ALERTS=true
TEAMS_WEBHOOK_URL=

# SSL Certificate Monitoring
# Alert when SSL certificate expiry is within N days
SSL_EXPIRY_WARNING_DAYS=30

# Timezone
TIMEZONE=UTC
