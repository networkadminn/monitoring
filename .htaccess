# =============================================================================
# .htaccess - Protect sensitive files and directories
# =============================================================================

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to includes directory
    RewriteRule ^includes/ - [F,L]

    # Block access to vendor directory
    RewriteRule ^vendor/ - [F,L]

    # Block access to composer files
    RewriteRule ^composer\.(json|lock)$ - [F,L]

    # Block access to cron runner from web
    RewriteRule ^cron_runner\.php$ - [F,L]
</IfModule>

# Block config.php direct access
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Block install.php direct access from web (allow only CLI)
<Files "install.php">
    Order deny,allow
    Deny from all
    # Allow only from localhost and private networks for development
    Allow from 127.0.0.1 ::1
    Allow from 192.168.0.0/16
    Allow from 10.0.0.0/8
    Allow from 172.16.0.0/12
</Files>

# Block bulk_add_sites.php from web (allow only CLI)
<Files "bulk_add_sites.php">
    Order deny,allow
    Deny from all
    # Allow only from localhost and private networks for development
    Allow from 127.0.0.1 ::1
    Allow from 192.168.0.0/16
    Allow from 10.0.0.0/8
    Allow from 172.16.0.0/12
</Files>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.datatables.net https://cdn.coverr.co https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none';"
</IfModule>
