# Block access to install.php from web
<Files "install.php">
    Order deny,allow
    Deny from all
    # Allow only from localhost and private networks
    Allow from 127.0.0.1 ::1
    Allow from 192.168.0.0/16
    Allow from 10.0.0.0/8
    Allow from 172.16.0.0/12
</Files>

# Alternative: Block completely (uncomment below and comment above)
# <Files "install.php">
#     Order deny,allow
#     Deny from all
# </Files>
